<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <!-- Day label -->
        <TextView
            android:id="@+id/tvWeekDay"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:textSize="13sp"
            android:textColor="#424242"
            android:textStyle="bold" />

        <!-- Credited -->
        <TextView
            android:id="@+id/tvWeekCredit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:gravity="end" />

        <TextView
            android:id="@+id/tvWeekCreditAmt"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.4"
            android:textSize="12sp"
            android:textColor="#81C784"
            android:gravity="end"
            android:layout_marginEnd="12dp" />

        <!-- Debited -->
        <TextView
            android:id="@+id/tvWeekDebit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#C62828"
            android:gravity="end" />

        <TextView
            android:id="@+id/tvWeekDebitAmt"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.4"
            android:textSize="12sp"
            android:textColor="#EF9A9A"
            android:gravity="end" />

    </LinearLayout>

    <View
        android:id="@+id/dividerWeekRow"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F2FF"
        android:visibility="gone" />

</LinearLayout>
