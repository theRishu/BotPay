<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg"
    android:padding="16dp">

    <!-- Week range + net -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#00000000"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="18dp"
            android:background="@drawable/bg_header_card">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📆  WEEK"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:textColor="#90CAF9"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvWeekRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NET"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:textColor="#90CAF9"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvWeekNet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+₹0.00"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Day rows card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/surface"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Column headers -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.8"
                    android:text="DAY"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:textColor="@color/muted"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:text="IN"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:textColor="@color/credit"
                    android:textStyle="bold"
                    android:gravity="end" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:text="OUT"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:textColor="@color/debit"
                    android:textStyle="bold"
                    android:gravity="end" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:text="NET"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:textColor="@color/primary_violet"
                    android:textStyle="bold"
                    android:gravity="end" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border"
                android:layout_marginBottom="4dp" />

            <!-- 7 day rows added programmatically -->
            <LinearLayout
                android:id="@+id/llDayRows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp" />

            <!-- Week total row -->
            <LinearLayout
                android:id="@+id/llWeekTotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="← swipe for previous week"
        android:textSize="11sp"
        android:textColor="@color/muted"
        android:gravity="center"
        android:layout_marginTop="16dp" />

</LinearLayout>
